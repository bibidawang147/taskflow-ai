{
  "name": "ai-workspace-membership",
  "version": "1.0.0",
  "description": "AI工作台会员体系模块",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "seed": "node tests/seed.js",
    "lint": "eslint ."
  },
  "keywords": [
    "membership",
    "workflow",
    "creator",
    "revenue"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.0",
    "mysql2": "^3.6.0",
    "node-cron": "^3.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "services/**/*.js",
      "routes/**/*.js",
      "middleware/**/*.js",
      "!**/node_modules/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ],
    "verbose": true
  }
}
