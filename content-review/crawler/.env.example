# ==================== API 配置 ====================

# 工作流平台后端地址
API_BASE_URL=http://localhost:3000

# AI 服务提供商: openai / dashscope / anthropic
AI_PROVIDER=openai

# ==================== OpenAI 配置 ====================
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

