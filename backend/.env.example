PORT=3000
NODE_ENV=development
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# PostgreSQL 数据库
DATABASE_URL="postgresql://username:password@localhost:5432/workflow_platform?schema=public"

# Redis 配置 (BullMQ 任务队列)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
WORKER_CONCURRENCY=5

# Sentry 监控 (可选但推荐)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# AI API Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-claude-api-key

# 阿里云百炼大模型配置
ALIBABA_API_KEY=your-alibaba-api-key
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIBABA_DEFAULT_MODEL=qwen-plus
ALIBABA_VISION_MODEL=qwen-vl-plus

# 通义千问API Key
QWEN_API_KEY=your-qwen-api-key

# 阿里云图片生成配置
ALIBABA_IMAGE_MODEL=wanx-v1
ALIBABA_IMAGE_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text2image/image-synthesis

# 阿里云视频生成配置
ALIBABA_VIDEO_TEXT_MODEL=wanx2.1-t2v-turbo
ALIBABA_VIDEO_IMAGE_MODEL=wanx-i2v-v1
ALIBABA_VIDEO_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/video-generation/video-synthesis

# 邮件服务 (SMTP) - 密码重置功能需要
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-authorization-code
SMTP_FROM="瓴积AI" <your-email@qq.com>

# 前端地址（用于密码重置链接拼接）
FRONTEND_URL=http://localhost:5173
