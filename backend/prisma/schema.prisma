// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // provider = "postgresql"
  // url      = env("DATABASE_URL")
  // 开发环境可选使用 SQLite
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String?
  avatar    String?

  // 微信登录
  wechatOpenId  String?  @unique
  wechatUnionId String?  @unique

  // 密码重置
  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 用户创建的工作流
  workflows Workflow[]

  // 工作流执行历史
  executions WorkflowExecution[]

  // 评论
  comments Comment[]

  // 评分
  ratings Rating[]

  // 收藏的工作流
  favorites Favorite[]

  // 工作项使用记录
  workItemUsage WorkItemUsage[]

  // 用户积分和余额
  balance UserBalance?

  // 使用日志
  usageLogs UsageLog[]

  // 充值订单
  rechargeOrders RechargeOrder[]

  // 用户等级（旧字段，保留兼容）
  tier String @default("free") // free, pro, enterprise

  // 会员角色（新邀请码/订阅系统使用）
  role          String    @default("free") // "free" | "pro" | "creator" | "admin"
  roleExpiresAt DateTime? // 会员到期时间，null 表示永久或免费用户

  // 兑换记录
  redemptions   PromoCodeRedemption[]
  // 订阅记录
  subscriptions Subscription[]
  // 用量限制
  usageLimits   UsageLimit[]

  // 工作台布局
  workspaceLayout WorkspaceLayout?

  // 收藏标签
  favoriteTags FavoriteTag[]

  // 导航偏好设置
  navigationPrefs UserNavigationPrefs?

  // AI推荐相关
  conversationHistory   ConversationHistory[]
  userIntents          UserIntent[]
  recommendationLogs   RecommendationLog[]
  workflowPreferences  UserWorkflowPreference[]

  // 社群相关
  posts         Post[]
  postLikes     PostLike[]
  workflowLikes WorkflowLike[]

  // AI对话会话
  chatSessions  ChatSession[]

  // 用户专属邀请码
  referralCode  String?  @unique

  @@map("users")
}

model Workflow {
  id          String  @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  isPublic    Boolean @default(false)
  isTemplate  Boolean @default(false)
  isDraft     Boolean @default(true) // 是否为草稿
  isFeatured  Boolean @default(false) // 精选工作流（超级管理员发布自动标注）
  category    String?
  tags        String? // 使用逗号分隔的字符串存储标签

  // 工作流配置（JSON格式存储节点和连接信息）
  config Json

  // 版本控制
  version String @default("1.0.0")

  // 使用统计
  usageCount Int    @default(0) // 使用次数
  rating     Float? // 平均评分（1-5分）

  // AI推荐相关字段
  matchKeywords    String?  // JSON数组: ["公众号", "文案", "标题优化"]
  useScenarios     String?  // JSON数组: ["涨粉", "提高打开率", "节省时间"]
  difficultyLevel  String   @default("beginner") // "beginner" | "intermediate" | "advanced"
  platformTypes    String?  // JSON数组: ["小红书", "公众号", "抖音"]
  contentTypes     String?  // JSON数组: ["文案", "视频", "图片"]
  combinationIds   String?  // JSON数组: 可组合使用的工作流ID列表

  // 推荐质量指标
  clickCount       Int      @default(0) // 推荐后的点击次数
  importCount      Int      @default(0) // 一键导入次数
  avgRelevanceScore Float?  // 平均推荐相关度评分

  // 原始来源信息（用于逆向生成工作流功能）
  sourceType     String? // 'url' | 'text' | 'image' | 'video' | 'pdf' | 'ppt' | 'code' | null
  sourceUrl      String? // 如果是从URL生成，保存原始URL
  sourceContent  String? // 文本内容或Base64编码的小文件
  sourceFilePath String? // 本地文件存储路径（用于较大文件）
  sourceTitle    String? // 原始标题或文件名
  sourceMeta     Json? // 元数据：{ fileType, fileSize, dimensions, duration, etc. }

  // 示例执行数据（帮助用户理解工作流如何使用）
  exampleInput  Json? // 示例输入数据
  exampleOutput Json? // 示例输出结果

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 作者
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // 工作流节点
  nodes WorkflowNode[]

  // 执行历史
  executions WorkflowExecution[]

  // 评论
  comments Comment[]

  // 评分
  ratings Rating[]

  // 收藏
  favorites Favorite[]

  // 工作流分类关联
  categoryRelations WorkflowCategoryRelation[]

  // AI推荐关联
  embedding          WorkflowEmbedding?
  recommendationLogs RecommendationLog[]
  userPreferences    UserWorkflowPreference[]

  // 点赞
  likes WorkflowLike[]

  // 前置准备项
  preparations WorkflowPreparation[]

  @@map("workflows")
}

model WorkflowNode {
  id       String @id @default(cuid())
  type     String // input, llm, tool, condition, output, step (新增步骤类型)
  label    String
  position Json // 节点在编辑器中的位置
  config   Json // 节点配置

  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  // 步骤详情（一对一关联）
  stepDetail WorkflowStepDetail?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workflow_nodes")
}

// 前置准备项
model WorkflowPreparation {
  id          String  @id @default(cuid())
  workflowId  String
  name        String  // 准备项名称，如 "VPN环境"、"Claude账号"
  description String? // 说明
  link        String? // 相关链接
  order       Int     @default(0) // 排序

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, order])
  @@map("workflow_preparations")
}

// 步骤详情（扩展 WorkflowNode）
model WorkflowStepDetail {
  id     String @id @default(cuid())
  nodeId String @unique

  // 基本信息
  stepDescription String? // 步骤说明：具体怎么做、为什么做
  expectedResult  String? // 预期结果：完成后应该得到什么

  // 工具和链接（JSON数组）
  // 格式: [{ name: string, url?: string, description?: string }]
  tools String? // JSON数组

  // 提示词（给AI的prompt）
  promptTemplate String? // 提示词模板

  // 步骤指引块（JSON数组）- 混合内容流，包含文本、工具、资源、提示词、媒体等
  // 格式: [{ id: string, type: 'text' | 'tool' | 'resource' | 'prompt' | 'media', ... }]
  guideBlocks String? // JSON数组

  // 演示媒体（JSON数组）
  // 格式: [{ type: 'image' | 'video', url: string, caption?: string }]
  demonstrationMedia String? // JSON数组

  // 相关资源（JSON数组）
  // 格式: [{ title: string, type: 'file' | 'link', url: string, description?: string }]
  relatedResources String? // JSON数组

  // 引用工作流
  referencedWorkflowId String? // 引用的其他工作流ID

  // 下一步指向配置（JSON）
  // 格式: { type: 'default' | 'conditional', conditions?: [{ label: string, targetNodeId: string }] }
  nextStepConfig String? // JSON对象

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  node WorkflowNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@map("workflow_step_details")
}

model WorkflowExecution {
  id          String  @id @default(cuid())
  status      String // pending, running, completed, failed
  input       Json? // 输入数据
  output      Json? // 输出数据
  error       String? // 错误信息
  duration    Int? // 执行时长(毫秒)
  progress    String? // 当前执行进度（当前节点ID或描述）
  nodeResults Json? // 每个节点的执行结果 { nodeId: result }

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  // 用户管理功能
  isFavorite  Boolean? @default(false) // 是否收藏
  notes       String? // 用户备注
  title       String? // 执行标题(用于孤岛记录)
  description String? // 执行描述(用于孤岛记录)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // 工作流关联改为可选,支持孤岛执行记录
  workflowId String?
  workflow   Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  // 临时配置(用于孤岛执行)
  tempConfig Json? // 如果没有关联工作流,存储临时的节点配置

  // 执行步骤详情
  steps ExecutionStep[]

  @@map("workflow_executions")
}

model ExecutionStep {
  id        String  @id @default(cuid())
  stepIndex Int // 步骤序号
  nodeId    String // 对应的节点ID
  nodeType  String // 节点类型
  status    String // pending, running, completed, failed
  input     Json? // 该步骤的输入
  output    Json? // 该步骤的输出
  error     String? // 错误信息
  duration  Int? // 执行时长(毫秒)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  executionId String
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@map("execution_steps")
}

model Tool {
  id          String  @id @default(cuid())
  name        String
  description String?
  category    String
  icon        String?

  // 工具配置schema
  configSchema Json

  // API配置
  apiConfig Json?

  isBuiltIn Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tools")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // 可以评论工作流或帖子(二选一)
  workflowId String?
  workflow   Workflow? @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)

  // 回复功能
  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@map("comments")
}

model Rating {
  id        String   @id @default(cuid())
  score     Int // 1-5分
  review    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  // 确保一个用户只能对一个工作流评分一次
  @@unique([userId, workflowId])
  @@map("ratings")
}

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  // 标签关联
  tagRelations FavoriteTagRelation[]

  // 确保一个用户只能收藏一个工作流一次
  @@unique([userId, workflowId])
  @@map("favorites")
}

// 工作项（日常工作功能）
model WorkItem {
  id          String  @id @default(cuid())
  name        String // 工作项名称，如 "文章撰写"
  icon        String // 图标，如 "📝"
  category    String // 分类，如 "text"
  description String? // 描述

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 使用记录
  usageStats WorkItemUsage[]

  @@map("work_items")
}

// 工作项使用记录
model WorkItemUsage {
  id         String   @id @default(cuid())
  userId     String
  workItemId String
  usedAt     DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([userId, workItemId, usedAt])
  @@map("work_item_usage")
}

// 用户积分余额
model UserBalance {
  id             String   @id @default(cuid())
  userId         String   @unique
  coins          Int      @default(0) // 积分余额（1000 coins = 1 元）
  freeQuota      Int      @default(10000) // 每日免费额度
  usedToday      Int      @default(0) // 今日已用
  quotaResetAt   DateTime // 额度重置时间
  totalRecharged Float    @default(0) // 累计充值金额
  totalConsumed  Int      @default(0) // 累计消耗积分

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_balance")
}

// AI 使用日志
model UsageLog {
  id           String   @id @default(cuid())
  userId       String
  workflowId   String?
  executionId  String? // 关联到工作流执行
  provider     String // 'openai', 'anthropic', 'doubao', 'qwen', 'zhipu'
  model        String // 'gpt-4o', 'claude-3.5-sonnet', 'doubao-pro'
  inputTokens  Int
  outputTokens Int
  totalTokens  Int
  cost         Int // 花费的积分
  requestType  String // 'chat', 'embedding', 'image'
  status       String // 'success', 'failed'
  errorMessage String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([workflowId, createdAt])
  @@map("usage_logs")
}

// 充值订单
model RechargeOrder {
  id            String    @id @default(cuid())
  userId        String
  orderNo       String    @unique // 订单号
  amount        Float // 充值金额（人民币）
  coins         Int // 获得的积分
  bonusCoins    Int       @default(0) // 赠送的积分
  status        String // 'pending', 'success', 'failed', 'refunded'
  paymentMethod String? // 'wechat', 'alipay', 'stripe'
  paymentId     String? // 第三方支付ID
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([orderNo])
  @@map("recharge_orders")
}

// 模型定价配置
model ModelPricing {
  id           String  @id @default(cuid())
  provider     String // 'openai', 'anthropic', 'doubao', 'qwen', 'zhipu'
  modelId      String // 模型ID，如 'gpt-4o'
  modelName    String // 显示名称，如 'GPT-4o'
  description  String? // 模型描述
  inputPrice   Int // 每1K tokens 输入价格（积分）
  outputPrice  Int // 每1K tokens 输出价格（积分）
  category     String // 'text', 'image', 'embedding'
  maxTokens    Int? // 最大token数
  features     Json? // 特性说明，如 {vision: true, functionCalling: true}
  isActive     Boolean @default(true)
  allowedTiers String  @default("free,pro,enterprise") // 允许使用的用户等级
  sortOrder    Int     @default(0) // 排序

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, modelId])
  @@index([isActive, category])
  @@map("model_pricing")
}

// 工作台布局配置
model WorkspaceLayout {
  id       String @id @default(cuid())
  userId   String @unique
  layout   Json // 存储卡片布局配置
  zoom     Float  @default(1.0) // 缩放比例
  snapshot Json? // 完整的工作台状态快照

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workspace_layouts")
}

// 收藏标签
model FavoriteTag {
  id     String  @id @default(cuid())
  userId String
  name   String
  color  String?
  icon   String?
  order  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagRelations FavoriteTagRelation[]

  @@map("favorite_tags")
}

// 收藏与标签的关联表
model FavoriteTagRelation {
  id         String @id @default(cuid())
  favoriteId String
  tagId      String

  createdAt DateTime @default(now())

  favorite Favorite    @relation(fields: [favoriteId], references: [id], onDelete: Cascade)
  tag      FavoriteTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([favoriteId, tagId])
  @@map("favorite_tag_relations")
}

// 工作流分类
model WorkflowCategory {
  id          String  @id @default(cuid())
  name        String
  icon        String?
  description String?
  order       Int     @default(0)
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflowRelations WorkflowCategoryRelation[]

  @@map("workflow_categories")
}

// 工作流与分类的关联
model WorkflowCategoryRelation {
  id         String @id @default(cuid())
  workflowId String
  categoryId String

  createdAt DateTime @default(now())

  workflow Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  category WorkflowCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([workflowId, categoryId])
  @@map("workflow_category_relations")
}

// 用户导航偏好设置
model UserNavigationPrefs {
  id                String  @id @default(cuid())
  userId            String  @unique
  collapsedSections String? // JSON数组，存储折叠的导航section IDs
  favoriteViewMode  String  @default("grid") // 'grid' | 'list'
  defaultTab        String  @default("explore") // 'explore' | 'workspace' | 'article'
  recentDaysRange   Int     @default(7) // 最近使用的天数范围

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_navigation_prefs")
}

// ==================== AI推荐系统模型 ====================

// 对话历史
model ConversationHistory {
  id           String   @id @default(cuid())
  userId       String
  sessionId    String   // 会话ID (同一次探索会话)

  // 对话内容
  userMessage  String   // 用户输入
  aiResponse   String   // AI回复
  messageType  String   @default("text") // "text" | "suggestion" | "comparison"

  // 识别的用户意图
  intentData   Json?    // 存储UserIntent结构

  // 推荐结果
  recommendedWorkflowIds String? // JSON数组: 本轮推荐的工作流ID列表

  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId, createdAt])
  @@map("conversation_history")
}

// 用户意图
model UserIntent {
  id              String   @id @default(cuid())
  userId          String
  sessionId       String
  conversationId  String?  // 关联到具体的对话

  // 意图维度
  platformType    String?  // "小红书" | "抖音" | "公众号" | "B站" | "视频号"
  contentType     String?  // "文案" | "视频" | "图片" | "数据分析"
  goal            String?  // "涨粉" | "变现" | "品牌建设" | "效率提升"
  skillLevel      String?  // "beginner" | "intermediate" | "advanced"
  urgency         String?  // "quick" | "deep" | "flexible"

  // 提取的关键词
  keywords        String?  // JSON数组

  // 置信度
  confidence      Float    @default(0.0) // 0-1之间

  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
  @@map("user_intents")
}

// 推荐日志
model RecommendationLog {
  id                String   @id @default(cuid())
  userId            String
  sessionId         String
  conversationId    String?  // 关联到具体的对话

  workflowId        String

  // 推荐计算详情
  relevanceScore    Float    // 相关度总分
  tagMatchScore     Float    // 标签匹配分
  scenarioScore     Float    // 场景相似度分
  popularityScore   Float    // 热度分
  personalizedScore Float    // 个性化调整分

  // 推荐位置
  position          Int      // 推荐列表中的位置 (1-based)
  displayType       String   // "highlight" | "normal" | "suggested"

  // 用户反馈
  userAction        String?  // "clicked" | "favorited" | "imported" | "dismissed" | "ignored"
  actionAt          DateTime?

  // 匹配理由
  matchReasons      String?  // JSON数组: ["平台匹配: 小红书", "功能匹配: 文案生成"]

  createdAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow          Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId, createdAt])
  @@index([workflowId, userAction])
  @@map("recommendation_logs")
}

// 用户工作流偏好
model UserWorkflowPreference {
  id              String   @id @default(cuid())
  userId          String
  workflowId      String

  // 偏好权重 (基于行为自动计算)
  preferenceScore Float    @default(0.0) // -1 到 1 之间

  // 行为统计
  viewCount       Int      @default(0)
  favoriteCount   Int      @default(0) // 收藏次数 (可能多次收藏/取消)
  importCount     Int      @default(0)
  executeCount    Int      @default(0) // 执行次数
  dismissCount    Int      @default(0) // 点击"不感兴趣"次数

  lastInteractedAt DateTime @updatedAt
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow         Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([userId, workflowId])
  @@map("user_workflow_preferences")
}

// 工作流向量索引 (用于语义搜索)
model WorkflowEmbedding {
  id          String   @id @default(cuid())
  workflowId  String   @unique

  // 向量数据 (存储为JSON)
  embedding   String   // JSON数组: 768维向量 (OpenAI text-embedding-3-small)

  // 元数据 (用于快速过滤)
  textContent String   // 用于生成embedding的文本内容
  model       String   // 使用的embedding模型

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_embeddings")
}

// ==================== 社群功能模型 ====================

// 讨论帖
model Post {
  id          String   @id @default(cuid())
  title       String
  content     String   // 帖子内容 (支持富文本/Markdown)
  tags        String?  // JSON数组: ["营销", "小红书"]

  // 统计数据
  viewCount    Int @default(0)
  likeCount    Int @default(0)
  commentCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 作者
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // 评论
  comments Comment[]

  // 点赞
  likes PostLike[]

  @@index([createdAt])
  @@index([likeCount])
  @@map("posts")
}

// 帖子点赞
model PostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("post_likes")
}

// 工作流点赞
model WorkflowLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([userId, workflowId])
  @@index([workflowId])
  @@map("workflow_likes")
}

// AI对话会话
model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("新对话")
  messages  Json     @default("[]") // 存储消息数组，格式: [{role: 'user'|'assistant', content: string, recommendedWorkflows?: any[]}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([updatedAt])
  @@map("chat_sessions")
}

// ==================== 邀请码/优惠码系统 ====================

// 邀请码/优惠码
model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique // 码本身，如 "LJINVITE-A3K9X2MN"

  // 码类型和效果
  type            String    // "invite" | "discount" | "gift" | "annual"
  plan            String    @default("pro") // 赠送什么等级："pro" | "creator"
  durationDays    Int       // 赠送天数，如 30（1个月）、365（1年）
  discountPercent Int?      // 折扣百分比（优惠码用），如 50 表示五折

  // 使用限制
  maxUses         Int?      // 最大使用次数，null 表示不限
  usedCount       Int       @default(0) // 已使用次数

  // 生效和过期
  isActive        Boolean   @default(true) // 是否启用
  startsAt        DateTime  @default(now()) // 码生效时间
  expiresAt       DateTime? // 码过期时间，null 表示永不过期

  // 元数据
  description     String?   // 备注说明，如 "早鸟邀请活动"
  createdBy       String?   // 创建者 userId
  batchId         String?   // 批次ID，方便按批次管理
  countsAsEarlyBird Boolean @default(false) // 兑换时计入早鸟名额

  // 关联
  redemptions     PromoCodeRedemption[]
  subscriptions   Subscription[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([code])
  @@index([type])
  @@index([batchId])
  @@index([isActive])
  @@map("promo_codes")
}

// 兑换记录
model PromoCodeRedemption {
  id          String   @id @default(cuid())

  codeId      String
  code        PromoCode @relation(fields: [codeId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  redeemedAt  DateTime  @default(now())

  // 同一个码同一个用户只能兑换一次
  @@unique([codeId, userId])
  @@index([userId])
  @@index([codeId])
  @@map("promo_code_redemptions")
}

// 订阅记录
model Subscription {
  id            String    @id @default(cuid())

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  plan          String    // "pro" | "creator"
  status        String    @default("active") // "active" | "expired" | "cancelled"
  source        String    // "invite_code" | "promo_code" | "purchase" | "gift" | "admin"

  promoCodeId   String?
  promoCode     PromoCode? @relation(fields: [promoCodeId], references: [id])

  startedAt     DateTime
  expiresAt     DateTime

  amount        Float?    // 支付金额
  paymentMethod String?   // 支付方式

  // 定价相关字段
  priceTier       String?   // "early_bird" | "growth" | "standard"
  originalPrice   Float?    // 下单时在售价
  paidAmount      Float?    // 实付金额
  isRenewal       Boolean   @default(false)
  renewalDiscount Float?    // 续费折扣率
  paymentId       String?   // 支付凭证号

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([priceTier])
  @@map("subscriptions")
}

// 功能用量限制
model UsageLimit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  feature   String   // "ai_convert" | "publish" | "replicate"
  usedCount Int      @default(0)
  resetAt   DateTime // 下次重置时间（每月1号）

  @@unique([userId, feature])
  @@index([userId])
  @@index([resetAt])
  @@map("usage_limits")
}

// ==================== 定价配置（全局单例） ====================

model PricingConfig {
  id                String   @id @default("singleton")

  currentTier       String   @default("early_bird") // "early_bird" | "growth" | "standard"

  // 各阶段价格
  earlyBirdPrice    Float    @default(199)
  growthPrice       Float    @default(349)
  standardPrice     Float    @default(499)

  // 早鸟名额控制
  earlyBirdLimit    Int      @default(500)
  earlyBirdSold     Int      @default(0)

  // 续费折扣
  renewalDiscount   Float    @default(0.7)   // 七折续费
  renewalWindowDays Int      @default(30)    // 到期前30天可续费

  // 阶段切换时间点
  growthStartAt     DateTime                 // 成长价开始时间
  standardStartAt   DateTime                 // 原价开始时间

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("pricing_config")
}

// ==================== 用户行为事件追踪 ====================

model UserEvent {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String
  event      String
  properties String?  // JSON string (SQLite 无原生 JSON 类型)
  page       String?
  referrer   String?
  timestamp  DateTime
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@index([sessionId, createdAt])
  @@map("user_events")
}
