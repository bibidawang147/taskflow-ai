# 生产环境配置示例
NODE_ENV=production
PORT=3000

# 前端域名（逗号分隔）
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# JWT 配置（必须使用强密钥！）
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_64_CHARACTER_RANDOM_STRING_IN_PRODUCTION
JWT_EXPIRES_IN=7d

# PostgreSQL 数据库
DATABASE_URL=postgresql://workflow_user:YOUR_STRONG_PASSWORD@localhost:5432/workflow_platform?schema=public

# Redis 缓存
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# 数据库备份配置
DB_NAME=workflow_platform
DB_USER=workflow_user
DB_PASSWORD=YOUR_STRONG_PASSWORD
DB_PORT=5432

# 阿里云百炼 API
ALIBABA_API_KEY=sk-9f74ae6c017b46249f8081cc4296b5a3
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIBABA_DEFAULT_MODEL=qwen-plus
ALIBABA_VISION_MODEL=qwen-vl-plus
ALIBABA_IMAGE_MODEL=wanx-v1
ALIBABA_IMAGE_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text2image/image-synthesis
ALIBABA_VIDEO_TEXT_MODEL=wanx2.1-t2v-turbo
ALIBABA_VIDEO_IMAGE_MODEL=wanx-i2v-v1
ALIBABA_VIDEO_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/video-generation/video-synthesis

# OpenAI API（可选）
OPENAI_API_KEY=your-openai-api-key

# Anthropic Claude API（可选）
ANTHROPIC_API_KEY=your-anthropic-api-key

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# 文件上传
MAX_FILE_SIZE=52428800
UPLOAD_PATH=./uploads

# 错误监控（推荐配置 Sentry）
SENTRY_DSN=
ERROR_REPORT_ENABLED=false

# 性能监控
ENABLE_APM=false
