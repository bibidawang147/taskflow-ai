                          value={editingModuleName}
                          onChange={(e) => setEditingModuleName(e.target.value)}
                          onBlur={() => {
                            if (editingModuleName.trim()) {
                              updateModuleName(module.id, editingModuleName.trim())
                            } else {
                              setEditingModuleId(null)
                              setEditingModuleName('')
                            }
                          }}
                          onKeyDown={(e) => {
                            if (e.key === 'Enter' && editingModuleName.trim()) {
                              updateModuleName(module.id, editingModuleName.trim())
                            } else if (e.key === 'Escape') {
                              setEditingModuleId(null)
                              setEditingModuleName('')
                            }
                          }}
                          onClick={(e) => e.stopPropagation()}
                          autoFocus
                          style={{
                            width: '90%',
                            fontSize: '14px',
                            fontWeight: '600',
                            textAlign: 'center',
                            border: '1px solid #8b5cf6',
                            borderRadius: '4px',
                            padding: '4px 8px',
                            backgroundColor: 'white',
                            color: '#374151',
                            outline: 'none',
                            marginBottom: '0.5rem'
                          }}
                        />
                      ) : (
                        <div
                          style={{
                            fontSize: '14px',
                            fontWeight: '600',
                            color: activeModule === module.id ? module.color : '#1f2937',
                            marginBottom: '0.5rem',
                            transition: 'color 0.3s'
                          }}
                          onDoubleClick={(e) => {
                            if (isEditingModules && module.id !== 'all') {
                              e.stopPropagation()
                              startEditingModule(module.id, module.name)
                            }
                          }}
                        >
                          {module.name}
                        </div>
                      )}

                      {/* 工作流数量指示器 */}
                      <div style={{
                        fontSize: '11px',
                        color: '#6b7280',
                        fontWeight: '500'
                      }}>
                        {module.id === 'text' ? '8个工具' :
                         module.id === 'image' ? '6个工具' :
                         module.id === 'video' ? '4个工具' :
                         module.id === 'marketing' ? '12个工具' :
                         module.id === 'product' ? '7个工具' : '5个工具'}
                      </div>

                      {/* 活跃状态指示器 */}
                      {activeModule === module.id && (
                        <div style={{
                          position: 'absolute',
                          top: '10px',
                          right: '10px',
                          width: '6px',
                          height: '6px',
                          backgroundColor: module.color,
                          borderRadius: '50%',
                          animation: 'pulse 2s infinite'
                        }}></div>
                      )}
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        )}

        {/* 当前职位工作台 */}
        {activeJobRole !== 'all' && (
          <div style={{
            marginTop: '2rem',
            padding: '1.5rem',
            backgroundColor: 'white',
            borderRadius: '16px',
            border: `2px solid ${jobRoles.find(r => r.id === activeJobRole)?.color}`,
            boxShadow: `0 8px 32px ${jobRoles.find(r => r.id === activeJobRole)?.color}20`
          }}>
            <div style={{ 
              display: 'flex', 
              alignItems: 'center', 
              justifyContent: 'space-between',
              marginBottom: '1.5rem'
            }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: '1rem' }}>
                <div style={{
                  width: '48px',
                  height: '48px',
                  backgroundColor: jobRoles.find(r => r.id === activeJobRole)?.color,
