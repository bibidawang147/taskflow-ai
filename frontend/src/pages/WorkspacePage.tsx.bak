                  }}>
                    {jobRoles.find(r => r.id === activeJobRole)?.name}工作台
                  </h3>
                  <p style={{ 
                    fontSize: '14px', 
                    color: '#6b7280',
                    margin: 0,
                    lineHeight: '1.4'
                  }}>
                    {jobRoles.find(r => r.id === activeJobRole)?.description}
                  </p>
                </div>
              </div>
              <div style={{
                backgroundColor: `${jobRoles.find(r => r.id === activeJobRole)?.color}15`,
                color: jobRoles.find(r => r.id === activeJobRole)?.color,
