                          <span style={{ filter: 'brightness(0) invert(1)', fontSize: '16px' }}>●</span>
                        ) : (
                          <span style={{ fontSize: '16px', color: '#6b7280' }}>●</span>
                        )}
                      </div>

                      {/* 模块名称 */}
