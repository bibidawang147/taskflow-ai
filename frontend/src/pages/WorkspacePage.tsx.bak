                  fontSize: '14px',
                  fontWeight: '600',
                  color: '#1f2937',
                  margin: 0
                }}>
                  工作模块
                </h4>
                <div style={{ display: 'flex', gap: '0.5rem' }}>
                  <button
                    onClick={() => setIsEditingModules(!isEditingModules)}
                    style={{
                      padding: '6px 12px',
                      backgroundColor: isEditingModules ? '#8b5cf6' : '#f3f4f6',
                      color: isEditingModules ? 'white' : '#6b7280',
                      border: 'none',
                      borderRadius: '8px',
                      fontSize: '12px',
                      fontWeight: '500',
                      cursor: 'pointer'
                    }}
                  >
                    {isEditingModules ? '完成编辑' : '编辑'}
                  </button>
