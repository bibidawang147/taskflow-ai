                      <div style={{
                        position: 'absolute',
                        top: '-15px',
                        right: '-15px',
                        width: '40px',
                        height: '40px',
                        background: `radial-gradient(circle, ${module.color}20, transparent)`,
                        borderRadius: '50%',
                        opacity: activeModule === module.id ? 1 : 0.3,
                        transition: 'opacity 0.3s'
                      }}></div>

                      {/* 图标区域 */}
                      <div style={{
                        width: '48px',
                        height: '48px',
                        backgroundColor: activeModule === module.id ? module.color : '#f3f4f6',
