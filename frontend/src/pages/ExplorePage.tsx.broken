                      {item.rank <= 3 ? ['🥇', '🥈', '🥉'][item.rank - 1] : item.rank}
                    </div>

                    {/* 工具信息 */}
                    <div style={{ flex: 1, minWidth: 0 }}>
                      <div style={{
                        fontSize: '14px',
                        fontWeight: '600',
                        color: '#1f2937',
                        marginBottom: '0.25rem',
                        overflow: 'hidden',
                        textOverflow: 'ellipsis',
                        whiteSpace: 'nowrap'
                      }}>
                        {item.name}
                      </div>
                      <div style={{ fontSize: '12px', color: '#6b7280', marginBottom: '0.25rem' }}>
                        {item.provider}
                      </div>
                      <div style={{ display: 'flex', gap: '0.75rem', fontSize: '11px', color: '#9ca3af' }}>
                        <span>⭐ {item.rating}</span>
                        <span>📊 {(item.uses / 1000).toFixed(0)}k</span>
                        <span style={{ color: getTrendColor(item.trend) }}>
                          {getTrendIcon(item.trend)}
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            {/* 查看更多 */}
            <div style={{
              padding: '0.75rem',
              textAlign: 'center',
              borderTop: '1px solid #f3f4f6',
              backgroundColor: '#fafafa'
            }}>
              <button style={{
                fontSize: '13px',
                color: '#3b82f6',
                fontWeight: '600',
                background: 'none',
                border: 'none',
                cursor: 'pointer'
              }}>
                查看完整榜单 →
              </button>
            </div>
          </div>
        </div>
      </div>

      {/* 工作包详情弹窗 */}
      {selectedPackageForDetail && (
        <WorkPackageDetailModal
          workPackage={selectedPackageForDetail}
          onClose={() => setSelectedPackageForDetail(null)}
          onImport={(pkg) => {
            setSelectedPackageForDetail(null)
            handleImportClick(pkg)
          }}
        />
      )}

      {/* 导入选择位置弹窗 */}
      {selectedPackageForImport && (
        <WorkPackageImportModal
          workPackage={selectedPackageForImport}
          onClose={() => setSelectedPackageForImport(null)}
          onConfirm={handleConfirmImport}
        />
      )}
    </div>
  )
}
